<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="fertilizingSowingMachine" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <mrPowerConsumer forcePointY="0" forcePointZ="-2.6" />

<!--

    hopper is divided into 5 parts :
    seeds = the 2 first part combined
    fertilizer = 3rd part + 4th + 5th (the 2 small tanks at the rear = 350L each)

    18T empty weight with 36 coulters and no additionnal weight

    bug : right and left wing are not at the same position in the i3d (0 0 0 point is not the same)

-->

    <parentFile xmlFilename="$data/vehicles/novag/tForcePlus950/tForcePlus950.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="12" />

            <!-- no brakes on the tracks -->
            <remove path="vehicle.attachable.brakeForce" />

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.2 -0.2" /> <!-- main body -->
            <set path="vehicle.base.components.component(0)#mass" value="5400" />

            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 -0.1 -0.6" /> <!--drawbar-->
            <set path="vehicle.base.components.component(1)#mass" value="1000" />

            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 0 0" /> <!--left track-->
            <set path="vehicle.base.components.component(2)#mass" value="1500" />

            <set path="vehicle.base.components.component(3)#centerOfMass" value="0 0 0" /> <!--right track-->
            <set path="vehicle.base.components.component(3)#mass" value="1500" />

            <set path="vehicle.base.components.component(4)#centerOfMass" value="0 -0.1 -1" /> <!--left wing -->
            <set path="vehicle.base.components.component(4)#mass" value="3200" />

            <set path="vehicle.base.components.component(5)#centerOfMass" value="0 0.089 -1.009" /> <!--right wing -->
            <set path="vehicle.base.components.component(5)#mass" value="3200" />


            <!-- wheels -->

            <!-- tracks -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="400"/> <!--left front -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="400"/> <!-- left back -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="400"/> <!-- right front -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="400"/> <!-- right back -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#restLoad" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#restLoad" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#restLoad" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#restLoad" value="6"/>

            <!-- wing wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="30"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="6"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#yOffset" value="0.006"/>




            <set path="vehicle.powerConsumer#maxForce" value="60" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="26" /> <!-- 2x air turbine (seeds + ferti) + hydraulic distribution -->
            <set path="vehicle.powerConsumer#ptoRpm" value="340" />



            <!-- seeds hopper center of mass, 8400L total -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.2 0.45"/> <!-- fertilizer 2700L + 350L + 350L = 3400L -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#fillTypes" value="fertilizer"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#capacity" value="3400"/>

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(1)#mrCenterOfMass" value="0 2.2 2.4"/> <!-- seeds = 5000L -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(1)#fillTypes" value="seeds"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(1)#capacity" value="5000"/>

            <set path="vehicle.sowingMachine#fillUnitIndex" value="2"/>
            <set path="vehicle.sprayer#fillUnitIndex" value="1"/>
            <set path="vehicle.sprayer#unloadInfoIndex" value="1"/>
            <set path="vehicle.sprayer#fillVolumeIndex" value="1"/>

            <!-- trailer hitch rot adjustment -->
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerRotLimitScale" value="1 0.92 1" />

            <!-- wing additional masses = 2x600kg per wing -->
            <remove path="vehicle.designConfigurations.designConfiguration(1).objectChange(3)" />
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(3)#node" value="4>" />
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(3)#mrAddMassActive" value="1200" />
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(3)#mrAddMassCOMActive" value="0.45 -0.25 -0.85" />
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(4)#node" value="5>" />
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(4)#mrAddMassActive" value="1200" />
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(4)#mrAddMassCOMActive" value="-0.45 -0.061 -0.841" />

            <!-- wing masses + main part additional masses = 2x1200kg + 2x2000kg -->
            <set path="vehicle.designConfigurations.designConfiguration(2)#name" value="6400 KG" />
            <remove path="vehicle.designConfigurations.designConfiguration(2).objectChange(4)" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(4)#node" value="tForcePlus950_main_component1" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(4)#mrAddMassActive" value="4000" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(4)#mrAddMassCOMActive" value="0 1.3 -2.3" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(5)#node" value="4>" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(5)#mrAddMassActive" value="1200" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(5)#mrAddMassCOMActive" value="0.45 -0.25 -0.85" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(6)#node" value="5>" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(6)#mrAddMassActive" value="1200" />
            <set path="vehicle.designConfigurations.designConfiguration(2).objectChange(6)#mrAddMassCOMActive" value="-0.45 -0.061 -0.841" />

            <!-- remove not realistic moving center of masses -->
            <remove path="vehicle.animations.animation(1).part(40)" />
            <remove path="vehicle.animations.animation(1).part(40)" />

            <!-- in working mode, raise a little the wing support wheels so that they do not bear all the weight -->
            <set path="vehicle.animations.animation(1).part(35)#startRot" value="10 0 0" />
            <set path="vehicle.animations.animation(1).part(37)#startRot" value="10 0 0" />
            <set path="vehicle.animations.animation(1).part(34)#startRot" value="10 0 0" />
            <set path="vehicle.animations.animation(1).part(36)#startRot" value="10 0 0" />


        </attributes>
    </parentFile>

</vehicle>