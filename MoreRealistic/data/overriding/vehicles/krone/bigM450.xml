<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="selfPropelledMower" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <!-- base game engine : this combine harvester is able to harvest 85T per hour. too far from reality (about 4x more than IRL) -->

    <MR>true</MR>
    <!-- hydrostatic transmission means we don't have the full engine power to the wheels. it depends on the hydraulics motors -->
    <mrTransmission isHydrostatic="true" maxRpmWanted="1250" ptoModeMaxRpmWanted="1650" powerRatio="0.85" />
    <mrMower cuttingWidth="10.36" powerFx="0.95" hasConditioner="true" > <!-- 316cm + 2x360cm // better efficiency since there is some overlap with the front mower working width-->
        <!-- mergers power - same order as genuine xml workModes -->
        <workMode idlePower="0" />
        <workMode idlePower="10" powerFx="1.1" />
        <workMode idlePower="5"  powerFx="1.05" />
        <workMode idlePower="5"  powerFx="1.05" />
    </mrMower>


            <!--

                about 16000kg empty
                weight : 64% front and 36% rear

            -->

    <parentFile xmlFilename="$data/vehicles/krone/bigM450/bigM450.xml">
        <attributes>


            <set path="vehicle.powerConsumer#ptoRpm" value="540"/>
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="0"/>

            <!-- main -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.6 -0.53"/>
            <set path="vehicle.base.components.component(0)#mass" value="9100"/>

            <!-- rear axle -->
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0 0"/>
            <set path="vehicle.base.components.component(1)#mass" value="800"/>

            <!-- left mower -->
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 -0.15 0"/>
            <set path="vehicle.base.components.component(2)#mass" value="1600"/>

            <!-- right mower -->
            <set path="vehicle.base.components.component(3)#centerOfMass" value="0 -0.15 0"/>
            <set path="vehicle.base.components.component(3)#mass" value="1600"/>

            <!-- front mower -->
            <set path="vehicle.base.components.component(4)#centerOfMass" value="0 0 0"/>
            <set path="vehicle.base.components.component(4)#mass" value="1200"/>

            <!-- joint between main and mowers -->
            <set path="vehicle.base.components.joint(1)#rotLimitSpring" value="1000 1000 1000" />
            <set path="vehicle.base.components.joint(1)#rotLimitDamping" value="100 100 100" />

            <set path="vehicle.base.components.joint(2)#rotLimitSpring" value="1000 1000 1000" />
            <set path="vehicle.base.components.joint(2)#rotLimitDamping" value="100 100 100" />

            <set path="vehicle.base.components.joint(3)#rotLimitSpring" value="1000 1000 1000" />
            <set path="vehicle.base.components.joint(3)#rotLimitDamping" value="100 100 100" />

            <set path="vehicle.base.components.joint(1)#transDrivePosition" value="0 1 0" />
            <set path="vehicle.base.components.joint(1)#transDriveSpring" value="0 1000 0" />
            <set path="vehicle.base.components.joint(1)#transDriveDamping" value="0 100 0" />
            <set path="vehicle.base.components.joint(1)#maxTransDriveForce" value="0 10.8 0" /> <!-- we want to lift about 1100kg => 10.8Kn -->

            <set path="vehicle.base.components.joint(2)#transDrivePosition" value="0 1 0" />
            <set path="vehicle.base.components.joint(2)#transDriveSpring" value="0 1000 0" />
            <set path="vehicle.base.components.joint(2)#transDriveDamping" value="0 100 0" />
            <set path="vehicle.base.components.joint(2)#maxTransDriveForce" value="0 10.8 0" /> <!-- we want to lift about 1100kg => 10.8Kn -->

            <set path="vehicle.base.components.joint(3)#transDrivePosition" value="0 1 0" />
            <set path="vehicle.base.components.joint(3)#transDriveSpring" value="0 1000 0" />
            <set path="vehicle.base.components.joint(3)#transDriveDamping" value="0 100 0" />
            <set path="vehicle.base.components.joint(3)#maxTransDriveForce" value="0 7.85 0" /> <!-- we want to lift about 800kg => 7.85Kn -->


            <!--wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="60"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="60"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="15"/>


            <set path="vehicle.powerConsumer#ptoRpm" value="540"/>
            <set path="vehicle.dischargeable.dischargeNode(0)#emptySpeed" value="90"/>

            <!-- no rear wheel brake on a combine harvester ! -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#brakeFactor" value="0" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#brakeFactor" value="0" />


            <!-- more power at the front wheels -->
            <set path="vehicle.motorized.differentialConfigurations.differentialConfiguration.differentials.differential(2)#torqueRatio" value="0.8" />


            <!-- Liebherr D946 A7-05 stageV 12L displacement // 79L/h @1700rpm and 331KW-->
            <!-- DEF = about 7% of the fuel rate ? => 5.5L/h -->
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(0)#usage" value="79"/>
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(1)#usage" value="5.5"/>

            <remove path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#torqueScale" value="1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#minRpm" value="800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxRpm" value="2100"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxForwardSpeed" value="42"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxBackwardSpeed" value="21"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#ptoMotorRpmRatio" value="3.0555"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minForwardGearRatio" value="11.30"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minBackwardGearRatio" value="22.50"/>

            <!-- governor regulation -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrGovernorRpmRange" value="110" />
            <!-- "combine harvester" = greater engine inertia than tractors or other vehicles -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrInertiaFx" value="1" />

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#brakeForce" value="20"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#rpm" value="600"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#torque" value="0.920"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#rpm" value="700"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#torque" value="1.250"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#rpm" value="800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#torque" value="1.510"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#rpm" value="900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#torque" value="1.900"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#rpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#torque" value="2.250"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#rpm" value="1200"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#torque" value="2.300"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#rpm" value="1300"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#torque" value="2.310"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#rpm" value="1350"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#torque" value="2.335"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(8)#rpm" value="1400"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(8)#torque" value="2.255"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(9)#rpm" value="1500"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(9)#torque" value="2.105"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(10)#rpm" value="1600"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(10)#torque" value="1.975"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(11)#rpm" value="1700"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(11)#torque" value="1.860"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(12)#rpm" value="1800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(12)#torque" value="1.755"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(13)#rpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(13)#torque" value="1.660"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(14)#rpm" value="2000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(14)#torque" value="1.575"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(15)#rpm" value="2100"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(15)#torque" value="1.495"/>

        </attributes>
    </parentFile>

</vehicle>