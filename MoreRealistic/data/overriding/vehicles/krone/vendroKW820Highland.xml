<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="tedder" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <!-- light construction tedder for hillside farming -->
    <mrTedder teddingWidth="8.2" powerFx="0.9" />

    <!--

        highland = hillside version (ligth)

        915kg

    -->

    <parentFile xmlFilename="$data/vehicles/krone/vendroKW820Highland/vendroKW820Highland.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="12" />

            <set path="vehicle.base.components.component(0)#mass" value="175" /> <!-- chassis -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1 0" />

            <set path="vehicle.base.components.component(1)#mass" value="175" /> <!-- attacher -->
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0 -0.1" />

            <set path="vehicle.base.components.component(2)#mass" value="180" /> <!-- left inner wing -->
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0.7 -0.15 0" />

            <set path="vehicle.base.components.component(3)#mass" value="60" /> <!-- left outer wing -->
            <set path="vehicle.base.components.component(3)#centerOfMass" value="-0.2 -0.2 0" />

            <set path="vehicle.base.components.component(4)#mass" value="180" /> <!-- right inner wing -->
            <set path="vehicle.base.components.component(4)#centerOfMass" value="-0.7 -0.15 0" />

            <set path="vehicle.base.components.component(5)#mass" value="60" /> <!-- right outer wing -->
            <set path="vehicle.base.components.component(5)#centerOfMass" value="0.2 -0.2 0" />

            <set path="vehicle.base.components.joint(0)#rotLimitSpring" value="10000 10000 10000" />
            <set path="vehicle.base.components.joint(0)#rotLimitDamping" value="1000 1000 1000" />



            <!-- correct wheels -->

            <!-- not possible to set correct tires, otherwise, the tool is not "flat" in working position (wings wheels too large -->
            <!-- <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1)#filename" value="$data/shared/wheels/tires/trelleborg/T510/15x6_00R6.xml"/> -->
            <!-- <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#filename" value="$data/shared/wheels/tires/trelleborg/T510/15x6_00R6.xml"/> -->
            <!-- <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3)#filename" value="$data/shared/wheels/tires/trelleborg/T510/15x6_00R6.xml"/> -->

            <!-- <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5)#filename" value="$data/shared/wheels/tires/trelleborg/T510/15x6_00R6.xml"/> -->
            <!-- <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6)#filename" value="$data/shared/wheels/tires/trelleborg/T510/15x6_00R6.xml"/> -->
            <!-- <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7)#filename" value="$data/shared/wheels/tires/trelleborg/T510/15x6_00R6.xml"/> -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#yOffset" value="0.015"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#yOffset" value="0.015"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#yOffset" value="0.01"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#yOffset" value="0.01"/>


            <remove path="vehicle.powerConsumer" />
            <set path="vehicle.powerConsumer#ptoRpm" value="420" />

            <remove path="vehicle.attachable.brakeForce" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#mrLowerRotationOffset" value="13" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#upperRotationOffset" value="28" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0).distanceToGround#lower" value="0.4" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0).distanceToGround#upper" value="0.85" />

            <!-- remove movingcenter of mass -->
            <remove path="vehicle.animations.animation(0).part(5)" />
            <remove path="vehicle.animations.animation(0).part(5)" />

        </attributes>
    </parentFile>

</vehicle>
