<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="cultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.1" forcePointZ="0.9" />

    <!--
        working width = 6.1m (rear roll = 6.25m)
        hp recommended = 220-270Hp (260hp min on uk website)
        working speed recommended = 10-15kph
        weight with double steelRunner, crossCutter Knive front tool and trueCut 610 discs and pneumatic brakes => 8800 kgs

        the brakes ystem is not visible in game. Be there should be a pneumatic or hydraulic brake system on this equipment


    -->

    <parentFile xmlFilename="$data/vehicles/vaderstad/carrierXL625/carrierXL625.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="18" />

            <set path="vehicle.powerConsumer#maxForce" value="42" />
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.65 0.1" />
            <set path="vehicle.base.components.component(0)#mass" value="7200" />

            <set path="vehicle.storeData.specs.workingWidth" value="6.1" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="130"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="130"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#initialCompression" value="24"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#initialCompression" value="24"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#restLoad" value="3.15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#restLoad" value="3.15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#supportsWheelSink" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#supportsWheelSink" value="true"/>

            <!-- double steel runner -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#brakeFactor" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#brakeFactor" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="150"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="150"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#restLoad" value="3.7"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#restLoad" value="3.7"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mrFrictionScale" value="0.9"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrFrictionScale" value="0.9"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mass" value="0.7"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mass" value="0.7"/>

            <set path="vehicle.attachable.brakeForce#force" value="1.5"/> <!-- small air brakes -->

            <!-- trailer hitch rot adjustment -->
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerRotLimitScale" value="1 0.86 1" />

            <!-- slower folding speed -->
            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration.foldingParts.foldingPart(0)#speedScale" value="0.5" />

            <!-- moving center of mass -->
            <set path="vehicle.animations.animation(0).part(14)#componentIndex" value="1" />
            <set path="vehicle.animations.animation(0).part(14)#startCenterOfMass" value="0 0.55 0" />
            <set path="vehicle.animations.animation(0).part(14)#endCenterOfMass" value="0 1.65 0" />
            <set path="vehicle.animations.animation(0).part(14)#startTime" value="3" />
            <set path="vehicle.animations.animation(0).part(14)#endTime" value="8" />

        </attributes>
    </parentFile>

</vehicle>