<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="fertilizingCultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.1" mrToolCategory="cultivators" /> <!-- MR engine can't guess it is a tine cultivator => we force the toolCategory for MR powerconsumer-->

    <!--
    base weight : ???kg

    only "deep" mode

    6.2m wide

    remove totally messed up powerConsumer settings

    -->

    <parentFile xmlFilename="$data/vehicles/zunhammer/vibro/vibro.xml">
        <attributes>

            <remove path="vehicle.powerConsumer" />

            <set path="vehicle.powerConsumer#forceNode" value="vibro_main_component1" />
            <set path="vehicle.powerConsumer#maxForce" value="40" />


            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.4 0.3" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="10"/>

            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#upperRotationOffset" value="4" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#mrLowerRotationOffset" value="0" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerRotLimitScale" value="0.05 0 0" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerTransLimitScale" value="0 0.2 0" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0).distanceToGround#lower" value="0.63" />

        </attributes>
    </parentFile>

</vehicle>