<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="combineDrivable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <!-- hydrostatic transmission means we don't have the full engine power to the wheels. it depends on the hydraulics motors -->
    <mrTransmission isHydrostatic="true" maxRpmWanted="1600" ptoModeMaxRpmWanted="1900" powerRatio="0.75" />
    <!-- chopperPowerFx below 1 means more efficient system than average = less power required -->
    <!-- threshingPowerFx below 1 means more efficient system than average = less power required -->
    <mrCombine chopperIdlePower="16" chopperPowerFx="0.8" unloadingPower="45" threshingIdlePower="75" threshingPowerFx="0.75" irlSpotTonPerHour="120" maxFieldThreshingSpeed="16" />

    <parentFile xmlFilename="$data/vehicles/johnDeere/seriesX9/seriesX9.xml">
        <attributes>

            <!-- rotary combine = very little grain losses -->
            <set path="vehicle.combine#threshingScale" value="0.997"/>

            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="0"/>


            <!-- about 27500kgs (empty, no fuel, front 61cm track, rear 500/85r30, 2WD) => about 28800kg with driver and full fluid tanks => about 13700kg on the rear axle with full fuel tank and DEF -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 2.15 0.52"/>
            <set path="vehicle.base.components.component(0)#mass" value="22050"/>
            <set path="vehicle.base.components.component(1)#mass" value="3000"/>

            <!-- override the motor.brakeForce setting = redundant -->
            <remove path="vehicle.motorized.brakeForce" />


            <!--********************************-->
            <!--24" tracks -->

            <!-- correct rear tire  -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4)#dimensions" value="500_85R30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5)#dimensions" value="500_85R30"/>

