<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="mower" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <!-- <mrPowerConsumer forcePointY="0.2" /> -->
    <mrMower cuttingWidth="6.3" powerFx="1.2" /> <!-- less efficient because more shafts to route the power to the cutter bars

    <!--

        3538kg
        952kg drawbar load
        no brakes

    -->

    <parentFile xmlFilename="$data/vehicles/vermeer/tm1410/tm1410.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="30" />

            <set path="vehicle.storeData.specs.neededPower" value="120" /> <!-- 110 pto hp required -->

            <!-- main -->
            <set path="vehicle.base.components.component(0)#mass" value="1260" />
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.5 -2.2" />

            <!-- drawbar -->
            <set path="vehicle.base.components.component(1)#mass" value="500" />
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0.2 -0.2" />

            <!-- link between left and right wing = lift and move down part -->
            <set path="vehicle.base.components.component(2)#mass" value="400" />
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 0 0" />

            <!-- left wing -->
            <set path="vehicle.base.components.component(3)#mass" value="600" />
            <set path="vehicle.base.components.component(3)#centerOfMass" value="0 0 0" />

            <!-- right wing -->
            <set path="vehicle.base.components.component(4)#mass" value="600" />
            <set path="vehicle.base.components.component(4)#centerOfMass" value="0 0 0" />

            <set path="vehicle.base.components.joint(1)#transDrivePosition" value="0 0.5 0" />
            <set path="vehicle.base.components.joint(1)#transDriveSpring" value="0 1000 0" />
            <set path="vehicle.base.components.joint(1)#transDriveDamping" value="0 100 0" />
            <set path="vehicle.base.components.joint(1)#maxTransDriveForce" value="0 9.8 0" /> <!-- we want to lift about 1000kg => 9.8Kn -->

            <remove path="vehicle.powerConsumer" />
            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <!-- <set path="vehicle.powerConsumer#forceNode" value="gmd3123F_main_component1" /> -->
            <!-- <set path="vehicle.powerConsumer#maxForce" value="1" />--> <!-- should be something like working width divide by 2. But the "component" is already sliding on the ground (no wheelshape), and so, there is already a draftforce present -->

            <!-- no brakes -->
            <remove path="vehicle.attachable.brakeForce" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="60"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="60"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="3"/>


            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration(0).foldingParts.foldingPart(0)#speedScale" value="0.8" />


        </attributes>
    </parentFile>

</vehicle>
