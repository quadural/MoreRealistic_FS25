<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="combineCutterFruitPreparer" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <mrPowerConsumer forcePointX="0" forcePointY="0" forcePointZ="6" />

    <!-- hydrostatic transmission means we don't have the full engine power to the wheels. it depends on the hydraulics motors -->
    <mrTransmission isHydrostatic="true" minRpmWanted="1200" maxRpmWanted="1650" powerRatio="0.92" />
    <!-- threshingPowerFx below 1 means more efficient system than average = less power required -->
    <mrCombine unloadingPower="30" threshingIdlePower="55" threshingPowerFx="1.08" irlSpotTonPerHour="140" maxFieldThreshingSpeed="12" />

    <parentFile xmlFilename="$data/vehicles/grimme/ventor4150/ventor4150.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="12" />
            <set path="vehicle.combine#threshingScale" value="0.99"/>

            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="0"/>

            <!-- about 33600kgs with full fuel/def tanks -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.5 -2"/> <!--main-->
            <set path="vehicle.base.components.component(0)#mass" value="23600"/>
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 -0.6 0"/> <!-- back axle -->
            <set path="vehicle.base.components.component(1)#mass" value="2000"/>
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 -0.6 -0.1"/> <!-- header -->
            <set path="vehicle.base.components.component(2)#mass" value="4500"/>

            <!-- add missing rotLimitSpring for back axle -->
            <set path="vehicle.base.components.joint(0)#rotLimitSpring" value="0 0 8000"/>
            <set path="vehicle.base.components.joint(0)#rotLimitDamping" value="0 0 40"/>
            <set path="vehicle.base.components.joint(0)#maxRotDriveForce" value="0 0 40"/>
            <set path="vehicle.base.components.joint(0)#rotDriveRotation" value="0 0 0"/>
            <set path="vehicle.base.components.joint(0)#rotDriveSpring" value="0 0 50"/>
            <set path="vehicle.base.components.joint(0)#rotDriveDamping" value="0 0 50"/>
            <set path="vehicle.base.components.joint(0)#breakable" value="false"/>


            <!-- spring between header and main -->
            <set path="vehicle.base.components.joint(1)#rotLimitSpring" value="6000 25000 6000"/>
            <set path="vehicle.base.components.joint(1)#rotLimitDamping" value="40 250 40"/>
            <set path="vehicle.base.components.joint(1)#allowsJointRotLimitMovement" value="true"/>

            <!--wheels -->

            <!-- correct front wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0)#filename" value="$data/shared/wheels/tires/mitas/SFT/900_70R32.xml"/> <!-- front wheel 1-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1)#filename" value="$data/shared/wheels/tires/mitas/SFT/900_70R32.xml"/> <!-- front wheel 2-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#filename" value="$data/shared/wheels/tires/mitas/SFT/900_60R38.xml"/> <!-- rear wheel 1-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3)#filename" value="$data/shared/wheels/tires/mitas/SFT/900_60R38.xml"/> <!-- rear wheel 2-->

            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0)#dimensions" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1)#dimensions" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#dimensions" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3)#dimensions" />


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="180"/> <!-- front wheel 1-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="180"/> <!-- front wheel 2-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="160"/> <!-- rear wheel 1-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="160"/> <!-- rear wheel 2-->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="100"/> <!-- header wheel 1 -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="100"/> <!-- header wheel 2 -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#spring" value="60"/> <!-- transport wheel 1 -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#spring" value="60"/> <!-- transport wheel 2 -->


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="60"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="60"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="35"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="35"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#damper" value="20"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#mrFrictionScale" value="0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#mrFrictionScale" value="0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#mrFrictionScale" value="0.8"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#mrFrictionScale" value="0.8"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#width" value="0.8"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#width" value="0.8"/>


            <set path="vehicle.powerConsumer#ptoRpm" value="450"/>
            <set path="vehicle.powerConsumer#maxForce" value="15" />
            <set path="vehicle.powerConsumer#forceNode" value="ventor4150_main_component1" />

            <set path="vehicle.dischargeable.dischargeNode(0)#emptySpeed" value="450"/> <!-- less than 1min to unload the full "tank" -->


            <!-- MTU OM 471 LA phase V // 92L/h @1600rpm and 390KW-->
            <!-- DEF = up to 4% of the fuel rate -->
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(0)#usage" value="92"/>
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(1)#usage" value="3.5"/>

            <remove path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#torqueScale" value="1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#minRpm" value="850"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxRpm" value="1800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrGovernorRpmRange" value="150"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxForwardSpeed" value="27"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxBackwardSpeed" value="13.2"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#ptoMotorRpmRatio" value="2.963"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#brakeForce" value="10"/>

            <!-- harvester = greater engine inertia than tractors or other vehicles -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrInertiaFx" value="2" />

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minForwardGearRatio" value="20"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minBackwardGearRatio" value="40"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#rpm" value="500"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#torque" value="0.800"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#rpm" value="850"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#torque" value="2.200"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#rpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#torque" value="2.490"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#rpm" value="1100"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#torque" value="2.560"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#rpm" value="1200"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#torque" value="2.590"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#rpm" value="1300"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#torque" value="2.600"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#rpm" value="1400"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#torque" value="2.550"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#rpm" value="1500"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#torque" value="2.450"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(8)#rpm" value="1600"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(8)#torque" value="2.330"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(9)#rpm" value="1700"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(9)#torque" value="2.180"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(10)#rpm" value="1800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(10)#torque" value="2.000"/>

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 3 -6"/>

            <!-- front wiper too fast -->
            <set path="vehicle.wipers.wiper(0).state(0)#animSpeed" value="0.45" />
            <set path="vehicle.wipers.wiper(0).state(1)#animSpeed" value="0.45" />
            <set path="vehicle.wipers.wiper(0).state(2)#animSpeed" value="0.7" />

            <!-- fix animation -->
            <set path="vehicle.animations.animation(3).part(6)#startRotLimit" value="0 0 0" />
            <set path="vehicle.animations.animation(3).part(6)#startRotLimitSpring" value="1000 25000 6000" />
            <set path="vehicle.animations.animation(3).part(6)#endRotLimitSpring" value="6000 25000 6000" />
            <set path="vehicle.animations.animation(3).part(6)#startRotLimitDamping" value="40 250 40" />
            <set path="vehicle.animations.animation(3).part(6)#endRotLimitDamping" value="40 250 40" />

            <!-- chopping unit "collision shape" is not bound to the header component => very weird behavior if the chopper collision is touching the ground = most of the time, the front axle is floating in the air at more than 3m from the ground -->

            <!-- 1: add the missing i3dMapping for the chopper unit collision shape-->
            <set path="vehicle.i3dMappings.i3dMapping(600)#id" value="fruitPreparerCollision" />
            <set path="vehicle.i3dMappings.i3dMapping(600)#node" value="0>0|4|7|0|2|15|21|1|0|0|13" />

            <!-- 2: link the collision shape to the "header" component instead of the main vehicle component -->
            <set path="vehicle.base.objectChanges.objectChange(0)#node" value="fruitPreparerCollision" />
            <set path="vehicle.base.objectChanges.objectChange(0)#parentNodeActive" value="ventor4150_header_component3" />

            <!-- 3: modify the folding animation to move the collision shape to the proper position both in work mode and road mode -->
            <set path="vehicle.animations.animation(3).part(100)#node" value="fruitPreparerCollision" />
            <set path="vehicle.animations.animation(3).part(100)#startTime" value="1" />
            <set path="vehicle.animations.animation(3).part(100)#endTime" value="4" />
            <set path="vehicle.animations.animation(3).part(100)#startTrans" value="0 -0.4 2.7" />
            <set path="vehicle.animations.animation(3).part(100)#endTrans" value="0 0.9 0.55" />
            <set path="vehicle.animations.animation(3).part(100)#startRot" value="25 0 0" />
            <set path="vehicle.animations.animation(3).part(100)#endRot" value="50 0 0" />


            <!-- crab steering bug : the fruit preparer area and the cutter area do not follow the anim = wrong work area in game when driving in crab mode -->

            <!-- 1: add the missing i3dMapping for the chopper unit collision shape-->
            <set path="vehicle.i3dMappings.i3dMapping(601)#id" value="workAreas" />
            <set path="vehicle.i3dMappings.i3dMapping(601)#node" value="0>0|5" />

            <!-- 2: modify the crab steering animation -->
            <set path="vehicle.animations.animation(0).part(15)#node" value="workAreas" />
            <set path="vehicle.animations.animation(0).part(15)#startTime" value="0" />
            <set path="vehicle.animations.animation(0).part(15)#endTime" value="1" />
            <set path="vehicle.animations.animation(0).part(15)#startRot" value="0 -8 0" />
            <set path="vehicle.animations.animation(0).part(15)#endRot" value="0 8 0" />
            <set path="vehicle.animations.animation(0).part(15)#startTrans" value="0.4 0 0" />
            <set path="vehicle.animations.animation(0).part(15)#endTrans" value="-0.4 0 0" />




        </attributes>
    </parentFile>

</vehicle>