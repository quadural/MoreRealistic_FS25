<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="cutter" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <!-- 4600kg without canola extension -> 4680kg in game with stabilizer wheels -->

    <!-- BUGS = reel lifting cylinders are not aligned correctely (visible when we lift the reel) -->

    <parentFile xmlFilename="$data/vehicles/claas/convioFlex1380/convioFlex1380.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="13" />
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.45 -0.2" />
            <set path="vehicle.base.components.component(0)#mass" value="4630"/>

            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="30" />
            <set path="vehicle.powerConsumer#maxForce" value="10" />
            <set path="vehicle.powerConsumer#forceNode" value="convioFlex1380_main_component1" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mass" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mass" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.05"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.05"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#initialCompression" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#initialCompression" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#supportsWheelSink" value="false"/>

            <!-- reel should move more toward forward if needed -->
            <set path="vehicle.cylindered.movingTools.movingTool(0).translation#transMin" value="-0.45" />

            <!-- reel should move more toward up if needed -->
            <set path="vehicle.cylindered.movingTools.movingTool(1).rotation#rotMin" value="-25" />

            <!-- reel speed function of ground speed -->
            <set path="vehicle.turnOnVehicle.turnedOnAnimation(0)#speedScale" value="0.8" />
            <set path="vehicle.turnOnVehicle.turnedOnAnimation(0)#mrMovingSpeedRatio" value="0.36" /> <!-- 2.78 meters per second (10kph) => anim speed ratio will be x1 -->

        </attributes>
    </parentFile>

</vehicle>