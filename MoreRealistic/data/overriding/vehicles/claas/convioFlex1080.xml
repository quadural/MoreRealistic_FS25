<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="cutter" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <!-- 4050kg without canola extension -->

    <parentFile xmlFilename="$data/vehicles/claas/convioFlex1080/convioFlex1080.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="16" />
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.45 -0.25" />
            <set path="vehicle.base.components.component(0)#mass" value="4000"/>

            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="22" />
            <set path="vehicle.powerConsumer#maxForce" value="9" />
            <set path="vehicle.powerConsumer#forceNode" value="convioFlex1080_main_component1" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mass" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mass" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.05"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.05"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#initialCompression" value="35"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#initialCompression" value="35"/>

            <set path="vehicle.animations.animation(3).part(0)#startRot" value="-10 0 0" />
            <set path="vehicle.animations.animation(3).part(0)#endRot" value="-22 0 0" />

        </attributes>
    </parentFile>

</vehicle>