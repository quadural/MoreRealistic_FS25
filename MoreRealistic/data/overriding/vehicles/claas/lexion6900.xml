<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="combineDrivable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <!-- problem = we need to be able to specify a different brakeforce depending on the wheel config selected => not the same value for tires or tracks -->
    <!-- solution = playing with the "brakeFactor of the wheelshape for tracks -->


    <MR>true</MR>
    <!-- hydrostatic transmission means we don't have the full engine power to the wheels. it depends on the hydraulics motors -->
    <mrTransmission isHydrostatic="true" maxRpmWanted="1600" ptoModeMaxRpmWanted="2000" powerRatio="0.8" />
    <!-- chopperPowerFx below 1 means more efficient system than average = less power required -->
    <!-- threshingPowerFx below 1 means more efficient system than average = less power required -->
    <mrCombine chopperIdlePower="15" chopperPowerFx="1" unloadingPower="43" threshingIdlePower="65" threshingPowerFx="0.8" irlSpotTonPerHour="49" maxFieldThreshingSpeed="13" />

    <parentFile xmlFilename="$data/vehicles/claas/lexion8900/lexion8900.xml">
        <attributes>

            <!-- straw walker combine with autuning = little grain losses -->
            <set path="vehicle.combine#threshingScale" value="0.98"/>

            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="0"/>


            <!-- about 17850kgs (full fuel/def tanks) => about 8500kg on the rear axle with full fuel tank and DEF -->
            <!-- 20250kg with tracks (TerraTrac version) -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.9 0.05"/>
            <set path="vehicle.base.components.component(0)#mass" value="12400"/>
            <set path="vehicle.base.components.component(1)#mass" value="2800"/>

            <!-- override the motor.brakeForce setting = redundant -->
            <remove path="vehicle.motorized.brakeForce" />

            <!--*************************-->
            <!-- tracks -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="120"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="120"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="10"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#rotationDamping" value="0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#rotationDamping" value="0.03"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#yOffset" value="-0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#yOffset" value="-0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#yOffset" value="0.04"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#yOffset" value="0.04"/>

            <!-- no rear wheel brake on a combine harvester ! -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#brakeFactor" value="0.5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#brakeFactor" value="0.5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#brakeFactor" value="0.5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#brakeFactor" value="0.5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#brakeFactor" value="0" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#brakeFactor" value="0" />

            <!-- additionnal track area for the front virtual wheels since they are bearing more weight -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mrTrackFx" value="5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrTrackFx" value="5" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mass" value="0.88"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mass" value="0.88"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mass" value="0.88"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mass" value="0.88"/>

            <!--*************************-->
            <!--wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#spring" value="180"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#spring" value="180"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#spring" value="120"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#spring" value="120"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#damper" value="10"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#initialCompression" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#initialCompression" value="30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#initialCompression" value="19"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#initialCompression" value="19"/>

            <!-- restload determine the lateral and longitudinal stiffness in the game -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#restLoad" value="8"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#restLoad" value="8"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#restLoad" value="3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#restLoad" value="3"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#rotationDamping" value="0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#rotationDamping" value="0.03"/>

            <!-- no rear wheel brake on a combine harvester ! -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#brakeFactor" value="0" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#brakeFactor" value="0" />

            <!-- no need for mass and center of mass changes -->
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).objectChange(0)" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).objectChange(0)" />

            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).objectChange(0)" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).objectChange(0)" />


            <set path="vehicle.powerConsumer#ptoRpm" value="540"/>
            <set path="vehicle.dischargeable.dischargeableConfigurations.dischargeableConfiguration(0).dischargeNode(0)#emptySpeed" value="180"/>



            <!-- this combine is 2WD in game -->
            <remove path="vehicle.motorized.differentialConfigurations.differentialConfiguration(1).differentials.differential(1)" />
            <remove path="vehicle.motorized.differentialConfigurations.differentialConfiguration(1).differentials.differential(1)" />

            <remove path="vehicle.motorized.differentialConfigurations.differentialConfiguration(0).differentials.differential(3)" />
            <remove path="vehicle.motorized.differentialConfigurations.differentialConfiguration(0).differentials.differential(3)" />

            <!-- ************************************************************************************************************************-->
            <!-- man D26 6 cylinders 12.4L/507hp/373KW same as fendt ideal 8 combine ? => D2676 LE121 // -->
            <!-- Fuel = 95L/h @1800rpm and 373KW -->
            <!-- DEF = no data => 4% of the fuel rate -->
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(0)#usage" value="95"/>
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(1)#usage" value="3.8"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minForwardGearRatio" value="14.6"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minBackwardGearRatio" value="40.73"/>

            <remove path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#torqueScale" value="1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#minRpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxRpm" value="2000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxForwardSpeed" value="42"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxBackwardSpeed" value="15"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#ptoMotorRpmRatio" value="3.61"/>

            <!-- governor regulation -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrGovernorRpmRange" value="100" />
            <!-- combine harvester = greater engine inertia than tractors or other vehicles -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrInertiaFx" value="1.3" />

            <!-- only the front wheels are braking -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#brakeForce" value="35"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#rpm" value="600"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#torque" value="1.400"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#rpm" value="700"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#torque" value="1.480"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#rpm" value="800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#torque" value="1.645"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#rpm" value="900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#torque" value="1.888"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#rpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#torque" value="2.420"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#rpm" value="1250"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#torque" value="2.436"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#rpm" value="1400"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#torque" value="2.420"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#rpm" value="1800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#torque" value="1.980"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(8)#rpm" value="1950"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(8)#torque" value="1.760"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(9)#rpm" value="2000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(9)#torque" value="1.540"/>


            <!-- ************************************************************************************************************************-->

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 3.8 0.75"/>

            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimit" value="0 0 0"/>
            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimitSpring" value="4000 31000 8000"/> <!-- z-axis / y-axis / x-axis -->
            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimitDamping" value="80 310 80"/>
            <set path="vehicle.attacherJoints.attacherJoint(0)#allowsJointRotLimitMovement" value="true"/>



            <!-- *********  END MR Modification  **************************** -->
            <!-- ************************************************************ -->




            <!-- Store data -->
            <set path="vehicle.storeData.name"  value="LEXION 6900"/>
            <set path="vehicle.storeData.specs.power" value="507"/>
            <set path="vehicle.storeData.image" value="$data/vehicles/claas/lexion6900/store_lexion6900.png"/>
            <set path="vehicle.storeData.price" value="405500"/>
            <set path="vehicle.storeData.shopTranslationOffset" value="0 -0.085 0"/>
            <set path="vehicle.storeData.shopRotationOffset" value="-0.149 0 0"/>

            <!-- Configs -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0)#price" value="25000"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1)#isSelectable" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1)#isDefault" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2)#isSelectable" value="true"/>

            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration(1)#isSelectable" value="false"/>

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1)#isSelectable" value="false"/>
            <set path="vehicle.fillVolume.fillVolumeConfigurations.fillVolumeConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.fillVolume.fillVolumeConfigurations.fillVolumeConfiguration(1)#isSelectable" value="false"/>

            <set path="vehicle.dischargeable.dischargeableConfigurations.dischargeableConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.dischargeable.dischargeableConfigurations.dischargeableConfiguration(1)#isSelectable" value="false"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1)#isSelectable" value="false"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2)#isSelectable" value="false"/>

            <set path="vehicle.pipe.pipeConfigurations.pipeConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.pipe.pipeConfigurations.pipeConfiguration(1)#isSelectable" value="false"/>

            <set path="vehicle.cylindered.cylinderedConfigurations.cylinderedConfiguration(0)#isSelectable" value="true"/>
            <set path="vehicle.cylindered.cylinderedConfigurations.cylinderedConfiguration(1)#isSelectable" value="false"/>





        </attributes>
    </parentFile>

    <!-- ONLY FOR ICON GENERATION -->
    <storeData>
        <name>LEXION 6900</name>
        <image>$data/vehicles/claas/lexion6900/store_lexion6900.png</image>
        <brand>CLAAS</brand>
        <category>harvesters</category>
        <vertexBufferMemoryUsage>0</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>0</indexBufferMemoryUsage>
        <textureMemoryUsage>0</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
