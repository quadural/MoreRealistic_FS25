<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="combineDrivable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <!-- about 24500kg with front 89cm tracks and rear 620 tires -->

    <MR>true</MR>
    <!-- hydrostatic transmission means we don't have the full engine power to the wheels. it depends on the hydraulics motors -->
    <mrTransmission isHydrostatic="true" maxRpmWanted="1600" ptoModeMaxRpmWanted="1850" powerRatio="0.75" />
    <!-- chopperPowerFx below 1 means more efficient system than average = less power required -->
    <!-- threshingPowerFx below 1 means more efficient system than average = less power required -->
    <mrCombine chopperIdlePower="18" chopperPowerFx="0.9" unloadingPower="44" threshingIdlePower="85" threshingPowerFx="0.95" irlSpotTonPerHour="110" maxFieldThreshingSpeed="20" />

    <parentFile xmlFilename="$data/vehicles/claas/lexion8900/lexion8900.xml">
        <attributes>

            <!-- rotary combine = very little grain losses -->
            <set path="vehicle.combine#threshingScale" value="0.995"/>

            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="0"/>


            <!-- about 22400kgs TT version with full fuel/DEF tanks -->

            <set path="vehicle.base.components.component(0)#mass" value="17650"/>
            <set path="vehicle.base.components.component(1)#mass" value="3000"/>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 2 0.2"/>
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 -0.1 0"/>


            <!-- override the motor.brakeForce setting = redundant -->
            <remove path="vehicle.motorized.brakeForce" />


            <!--********************************-->
            <!--89cm tracks -->



            <!-- correct rear tire  -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4)#filename" value="$data/shared/wheels/tires/vredestein/traxionHarvest/620_70R30.xml"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5)#filename" value="$data/shared/wheels/tires/vredestein/traxionHarvest/620_70R30.xml"/>

            <!-- inverted rear tire (no 4WD) -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).tire#isInverted" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).tire#isInverted" value="true"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="250"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="250"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="150"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="150"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="15"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#rotationDamping" value="0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#rotationDamping" value="0.03"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#yOffset" value="-0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#yOffset" value="0.0045"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#yOffset" value="-0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#yOffset" value="0.0045"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#yOffset" value="0.041"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#yOffset" value="0.041"/>

            <!-- no rear wheel brake on a combine harvester ! -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#brakeFactor" value="1" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#brakeFactor" value="1" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#brakeFactor" value="1" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#brakeFactor" value="1" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#brakeFactor" value="0" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#brakeFactor" value="0" />

            <!-- additionnal track area for the front virtual wheels since they are bearing more weight -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mrTrackFx" value="5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrTrackFx" value="5" />

            <!-- more weight fortracks -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mass" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mass" value="0.5"/>



            <!--********************************-->

            <set path="vehicle.powerConsumer#ptoRpm" value="540"/>
            <set path="vehicle.dischargeable.dischargeableConfigurations.dischargeableConfiguration(1).dischargeNode(0)#emptySpeed" value="180"/>



            <!-- no 4WD on this combine in game -->
            <remove path="vehicle.motorized.differentialConfigurations.differentialConfiguration.differentials(0).differential(3)" />
            <remove path="vehicle.motorized.differentialConfigurations.differentialConfiguration.differentials(0).differential(3)" />

            <!-- more torque on the "front" tracks wheels since they are bearing more weight -->
            <set path="vehicle.motorized.differentialConfigurations.differentialConfiguration.differentials(0).differential(0)#torqueRatio" value="0.3" />
            <set path="vehicle.motorized.differentialConfigurations.differentialConfiguration.differentials(0).differential(1)#torqueRatio" value="0.3" />

            <!-- ************************************************************************************************************************-->
            <!-- 8800 = MAN D4276 LE, VAG turbo // 128L/h @1800rpm and 515KW-->
            <!-- DEF = about 8% of the fuel rate -->
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(1).consumer(0)#usage" value="128"/>
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(1).consumer(1)#usage" value="10"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).transmission#minForwardGearRatio" value="15"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).transmission#minBackwardGearRatio" value="37.7"/>

            <remove path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#torqueScale" value="1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#minRpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#maxRpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#maxForwardSpeed" value="40.1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#maxBackwardSpeed" value="16"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#ptoMotorRpmRatio" value="3.3333"/>

            <!-- governor regulation -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#mrGovernorRpmRange" value="200" />
            <!-- combine harvester = greater engine inertia than tractors or other vehicles -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#mrInertiaFx" value="1.5" />

            <!-- only the front wheels are braking -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor#brakeForce" value="26"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(0)#rpm" value="700"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(0)#torque" value="1.700"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(1)#rpm" value="950"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(1)#torque" value="3.200"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(2)#rpm" value="1500"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(2)#torque" value="3.215"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(3)#rpm" value="1800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(3)#torque" value="2.730"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(4)#rpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(1).motor.torque(4)#torque" value="2.470"/>


            <!-- ************************************************************************************************************************-->
            <!-- 8900 = MAN D4276 LE, fixed turbo // 145L/h @1750rpm and 581KW-->
            <!-- DEF = about 8% of the fuel rate -->
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(2).consumer(0)#usage" value="145"/>
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(2).consumer(1)#usage" value="11"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).transmission#minForwardGearRatio" value="15"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).transmission#minBackwardGearRatio" value="37.7"/>

            <remove path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#torqueScale" value="1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#minRpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#maxRpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#maxForwardSpeed" value="40.1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#maxBackwardSpeed" value="16"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#ptoMotorRpmRatio" value="3.3333"/>

            <!-- governor regulation -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#mrGovernorRpmRange" value="200" />
            <!-- combine harvester = greater engine inertia than tractors or other vehicles -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#mrInertiaFx" value="1.5" />

            <!-- only the front wheels are braking -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor#brakeForce" value="26"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(0)#rpm" value="700"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(0)#torque" value="1.700"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(1)#rpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(1)#torque" value="1.800"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(2)#rpm" value="1200"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(2)#torque" value="3.040"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(3)#rpm" value="1350"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(3)#torque" value="3.400"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(4)#rpm" value="1600"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(4)#torque" value="3.400"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(5)#rpm" value="1750"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(5)#torque" value="3.170"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(6)#rpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(2).motor.torque(6)#torque" value="2.840"/>


            <!-- ************************************************************************************************************************-->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 4.1 0.65"/>

            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimit" value="0 0 0"/>
            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimitSpring" value="5000 37000 9500"/> <!-- z-axis / y-axis / x-axis -->
            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimitDamping" value="100 370 100"/>
            <set path="vehicle.attacherJoints.attacherJoint(0)#allowsJointRotLimitMovement" value="true"/>

            <!-- slow down folding speed -->
            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration(1).foldingParts.foldingPart(0)#speedScale" value="0.3" />

        </attributes>
    </parentFile>

</vehicle>