<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="combineDrivable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <!-- about 29000kg with front 91cm tracks and rear 750 tires and full fuel tanks => about 28600kg in game config with tracks
         about 27500kg with dual 710 front and 750 rear
    -->

    <!-- the CR11 model doesn't seem compatible with 26inches tracks => 32 or 36 tracks required (81 and 91cm)
         tracks i3d = 61cm wide. cr11 xml "trackWidth" param = 1.3 => 1.3 * 61 = 79.3cm
    -->

    <MR>true</MR>
    <!-- hydrostatic transmission means we don't have the full engine power to the wheels. it depends on the hydraulics motors -->
    <mrTransmission isHydrostatic="true" maxRpmWanted="1300" ptoModeMaxRpmWanted="1900" powerRatio="0.9" />
    <!-- chopperPowerFx below 1 means more efficient system than average = less power required -->
    <!-- threshingPowerFx below 1 means more efficient system than average = less power required -->
    <mrCombine chopperIdlePower="20" chopperPowerFx="0.9" unloadingPower="52" threshingIdlePower="90" threshingPowerFx="0.84" irlSpotTonPerHour="125" maxFieldThreshingSpeed="16" />

    <parentFile xmlFilename="$data/vehicles/newHolland/cr11/cr11.xml">
        <attributes>

            <!-- incorrect shop display value -->
            <set path="vehicle.storeData.specs.maxSpeed" value="40" />

            <!-- rotary combine = very little grain losses -->
            <set path="vehicle.combine#threshingScale" value="0.997"/>

            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="0"/>


            <!-- about 27000kgs TT version with full fuel/DEF tanks -->

            <set path="vehicle.base.components.component(0)#mass" value="19600"/>
            <set path="vehicle.base.components.component(1)#mass" value="3000"/>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 2 0.4"/>
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0 0"/>


            <!-- override the motor.brakeForce setting = redundant -->
            <remove path="vehicle.motorized.brakeForce" />


            <!--********************************-->
            <!--81cm tracks -->

            <!-- better rear tire to match the 81cm front tracks  -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(4)#dimensions" value="620_70R30"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(5)#dimensions" value="620_70R30"/>


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#spring" value="250"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#spring" value="250"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(4).physics#spring" value="150"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(5).physics#spring" value="150"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#damper" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(4).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(5).physics#damper" value="15"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(4).physics#rotationDamping" value="0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(5).physics#rotationDamping" value="0.03"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#yOffset" value="0.01"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#yOffset" value="0.01"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(4).physics#yOffset" value="0.06"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(5).physics#yOffset" value="0.06"/>

            <!-- no rear wheel brake on a combine harvester ! -->
            <!-- 0.5 factor for tracks because the brake force is set for 2 front wheels, not 4 -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#brakeFactor" value="0.6" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#brakeFactor" value="0.6" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#brakeFactor" value="0.6" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#brakeFactor" value="0.6" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(4).physics#brakeFactor" value="0" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(5).physics#brakeFactor" value="0" />

            <!-- additionnal track area for the front virtual wheels since they are bearing more weight -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#mrTrackFx" value="5" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#mrTrackFx" value="5" />

            <!-- more weight for tracks -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#mass" value="0.95"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#mass" value="0.95"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#mass" value="0.95"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#mass" value="0.95"/>


            <!--********************************-->
            <!--front duals -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#spring" value="400"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#spring" value="400"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#spring" value="170"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#spring" value="170"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#damper" value="35"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#damper" value="35"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#damper" value="17"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#damper" value="17"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#rotationDamping" value="0.03"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#rotationDamping" value="0.03"/>

            <!-- no rear wheel brake on a combine harvester ! -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#brakeFactor" value="1" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#brakeFactor" value="1" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#brakeFactor" value="0" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#brakeFactor" value="0" />


            <!-- differential config for tracks = more torque for the tracks -->
            <set path="vehicle.motorized.differentialConfigurations.differentialConfiguration(0).differentials.differential(4)#torqueRatio" value="0.9" />


            <!-- differential config for wheels = more torque on the front axle -->
            <set path="vehicle.motorized.differentialConfigurations.differentialConfiguration(1).differentials.differential(2)#torqueRatio" value="0.9" />


            <!--********************************-->

            <set path="vehicle.powerConsumer#ptoRpm" value="540"/>
            <set path="vehicle.dischargeable.dischargeNode(0)#emptySpeed" value="211"/>
            <set path="vehicle.dischargeable.dischargeNode(1)#emptySpeed" value="211"/>


            <!-- ************************************************************************************************************************-->
            <!-- FPT CURSOR 16 // 142L/h @1800rpm and 570KW-->
            <!-- DEF = about 8% of the fuel rate -->
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(0)#usage" value="142"/>
            <set path="vehicle.motorized.consumerConfigurations.consumerConfiguration(0).consumer(1)#usage" value="12"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minForwardGearRatio" value="12.3"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).transmission#minBackwardGearRatio" value="30.63"/>

            <remove path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#torqueScale" value="1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#minRpm" value="1000"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxRpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxForwardSpeed" value="40.1"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#maxBackwardSpeed" value="16"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#ptoMotorRpmRatio" value="3.5185"/>

            <!-- governor regulation -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrGovernorRpmRange" value="120" />
            <!-- combine harvester = greater engine inertia than tractors or other vehicles -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#mrInertiaFx" value="1.6" />

            <!-- only the front wheels are braking -->
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor#brakeForce" value="40"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#rpm" value="600"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(0)#torque" value="1.940"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#rpm" value="800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(1)#torque" value="2.370"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#rpm" value="1155"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(2)#torque" value="3.000"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#rpm" value="1400"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(3)#torque" value="3.280"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#rpm" value="1500"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(4)#torque" value="3.323"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#rpm" value="1680"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(5)#torque" value="3.220"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#rpm" value="1800"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(6)#torque" value="3.025"/>

            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#rpm" value="1900"/>
            <set path="vehicle.motorized.motorConfigurations.motorConfiguration(0).motor.torque(7)#torque" value="2.625"/>




            <!-- ************************************************************************************************************************-->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 4 1.2"/>

            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimit" value="0 0 0"/>
            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimitSpring" value="5000 37000 9500"/> <!-- z-axis / y-axis / x-axis -->
            <set path="vehicle.attacherJoints.attacherJoint(0)#rotLimitDamping" value="100 370 100"/>
            <set path="vehicle.attacherJoints.attacherJoint(0)#allowsJointRotLimitMovement" value="true"/>

            <!-- slow down attacher joint raise/lower speed -->
            <set path="vehicle.attacherJoints.attacherJoint(0)#moveTime" value="3.5"/>

            <!-- slow down folding speed -->
            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration(0).foldingParts.foldingPart(0)#speedScale" value="0.75" />

            <!-- 105° auger swivel ! -->
            <set path="vehicle.animations.animation(0).part(0)#endRot" value="0 -105 0" />

        </attributes>
    </parentFile>

</vehicle>