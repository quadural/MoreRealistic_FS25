<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="cultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0" forcePointZ="-0.8" />

    <!--

        light disc cultivator

        working speed = 10-15kph

        9200kg with LTX roller => 9410kg with disk roller SDR

    -->

    <parentFile xmlFilename="$data/vehicles/farmet/softer11/softer11.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#mass" value="3260" /> <!-- main -->
            <set path="vehicle.base.components.component(1)#mass" value="900" /> <!-- left inner wing -->
            <set path="vehicle.base.components.component(2)#mass" value="600" /> <!-- left outer wing-->
            <set path="vehicle.base.components.component(3)#mass" value="900" /> <!-- right inner wing -->
            <set path="vehicle.base.components.component(4)#mass" value="600" /> <!-- right outer wing-->

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.8 -1.2" />
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0 -0.55" />
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 0.1 -0.4" />
            <set path="vehicle.base.components.component(3)#centerOfMass" value="0 0 -0.55" />
            <set path="vehicle.base.components.component(4)#centerOfMass" value="0 0.1 -0.4" />

            <!-- transport wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="200"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="200"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#initialCompression" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#initialCompression" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#restLoad" value="3.65"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#restLoad" value="3.65"/>

            <!-- front support wheels -->
            <!-- correct tires should be bkt AW702 or AW909 10/75R15.3 -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#filename" value="$data/shared/wheels/tires/trelleborg/AW305/260_70R15_3.xml"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3)#filename" value="$data/shared/wheels/tires/trelleborg/AW305/260_70R15_3.xml"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4)#filename" value="$data/shared/wheels/tires/trelleborg/AW305/260_70R15_3.xml"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5)#filename" value="$data/shared/wheels/tires/trelleborg/AW305/260_70R15_3.xml"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#yOffset" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#yOffset" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#yOffset" value="0.025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#yOffset" value="0.025"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#restLoad" value="0.6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#restLoad" value="0.3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#restLoad" value="0.6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#restLoad" value="0.3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#rotationDamping" value="0.001"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#rotationDamping" value="0.001"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#rotationDamping" value="0.001"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#rotationDamping" value="0.001"/>

            <!-- roller wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(8).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(9).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(10).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(11).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(8).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(9).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(10).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(11).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#restLoad" value="2.2"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#restLoad" value="2.2"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(8).physics#restLoad" value="0.65"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(9).physics#restLoad" value="0.75"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(10).physics#restLoad" value="0.75"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(11).physics#restLoad" value="0.65"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#mass" value="0.275"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#mass" value="0.275"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(8).physics#mass" value="0.55"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(9).physics#mass" value="0.55"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(10).physics#mass" value="0.55"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(11).physics#mass" value="0.55"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#rotationDamping" value="0.0015"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#rotationDamping" value="0.0015"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(8).physics#rotationDamping" value="0.003"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(9).physics#rotationDamping" value="0.003"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(10).physics#rotationDamping" value="0.003"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(11).physics#rotationDamping" value="0.003"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#brakeFactor" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#brakeFactor" value="0"/>



            <set path="vehicle.attachable.brakeForce#force" value="2" /> <!-- air brakes -->

            <set path="vehicle.powerConsumer#maxForce" value="52" />
            <set path="vehicle.base.speedLimit#value" value="16" />



            <!-- IRL, the wings are not "free" at work = add some "spring" to put more force on the outer "wheels" -->
            <!-- <set path="vehicle.animations.animation(0).part()#" -->
            <set path="vehicle.base.components.joint(0)#rotDriveRotation" value="0 0 5" />
            <set path="vehicle.base.components.joint(0)#rotDriveSpring" value="0 0 10" />
            <set path="vehicle.base.components.joint(0)#rotDriveDamping" value="0 0 10" />
            <set path="vehicle.base.components.joint(0)#maxRotDriveForce" value="0 0 10" />

            <set path="vehicle.base.components.joint(1)#rotDriveRotation" value="0 0 5" />
            <set path="vehicle.base.components.joint(1)#rotDriveSpring" value="0 0 10" />
            <set path="vehicle.base.components.joint(1)#rotDriveDamping" value="0 0 10" />
            <set path="vehicle.base.components.joint(1)#maxRotDriveForce" value="0 0 5" />

            <set path="vehicle.base.components.joint(2)#rotDriveRotation" value="0 0 -5" />
            <set path="vehicle.base.components.joint(2)#rotDriveSpring" value="0 0 10" />
            <set path="vehicle.base.components.joint(2)#rotDriveDamping" value="0 0 10" />
            <set path="vehicle.base.components.joint(2)#maxRotDriveForce" value="0 0 10" />

            <set path="vehicle.base.components.joint(3)#rotDriveRotation" value="0 0 -5" />
            <set path="vehicle.base.components.joint(3)#rotDriveSpring" value="0 0 10" />
            <set path="vehicle.base.components.joint(3)#rotDriveDamping" value="0 0 10" />
            <set path="vehicle.base.components.joint(3)#maxRotDriveForce" value="0 0 5" />

            <!-- remove unreal moving center of mass -->
            <remove path="vehicle.animations.animation(0).part(22)" />
            <remove path="vehicle.animations.animation(0).part(27)" />
            <remove path="vehicle.animations.animation(0).part(30)" />
            <remove path="vehicle.animations.animation(0).part(31)" />

            <!-- trailer hitch rot adjustment -->
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerRotLimitScale" value="1 0.98 1" />

            <!-- roller rotating speed depending on the correct wheelshape, not the front support wheels ! -->
            <set path="vehicle.speedRotatingParts.speedRotatingPart(5)#wheelIndex" value="9" />
            <set path="vehicle.speedRotatingParts.speedRotatingPart(6)#wheelIndex" value="10" />
            <set path="vehicle.speedRotatingParts.speedRotatingPart(7)#wheelIndex" value="7" />
            <set path="vehicle.speedRotatingParts.speedRotatingPart(8)#wheelIndex" value="11" />
            <set path="vehicle.speedRotatingParts.speedRotatingPart(9)#wheelIndex" value="12" />
            <remove path="vehicle.speedRotatingParts.speedRotatingPart(7)#foldMinLimit" />
            <remove path="vehicle.speedRotatingParts.speedRotatingPart(7)#foldMaxLimit" />

        </attributes>
    </parentFile>

</vehicle>