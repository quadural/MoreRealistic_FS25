<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="cultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.66" forcePointZ="-0.5" />

    <!--

        basic machine weight without discs additionnal mass = 5590kg
        only 3cm working depth (estimate without mass)
        this is not a cultivator IRL

        Manual = "It is recommended that you drive at approximately 12 km/h, but you should
        always adjust your speed according to the conditions."

        gross weight = 5590kg
        seeding unit = Einböck seed drill = 200kg
        brakes = 50kg
        axle load = 0.84 x gross weight
        support load = 0.16 gross weight

    -->

    <parentFile xmlFilename="$data/vehicles/dalbo/powerchain800/powerchain800.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#mass" value="2300" /> <!-- main -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.1 -0.8" />

            <set path="vehicle.base.components.component(1)#mass" value="250" /> <!-- attacher -->
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 -0.1 -0.25" />

            <set path="vehicle.base.components.component(2)#mass" value="1400" /> <!-- left wing -->
            <set path="vehicle.base.components.component(2)#centerOfMass" value="-0.5 -0.2 0" />

            <set path="vehicle.base.components.component(3)#mass" value="1400" /> <!-- right wing -->
            <set path="vehicle.base.components.component(3)#centerOfMass" value="0.5 -0.2 -0.4" />

            <!-- mass change when seeding unit is present -->
            <remove path="vehicle.vehicleTypeConfigurations.vehicleTypeConfiguration(1).objectChange(6)"/>
            <set path="vehicle.vehicleTypeConfigurations.vehicleTypeConfiguration(1).objectChange(6)#node" value="powerchain800_main_component1"/>
            <set path="vehicle.vehicleTypeConfigurations.vehicleTypeConfiguration(1).objectChange(6)#mrAddMassActive" value="200"/>
            <set path="vehicle.vehicleTypeConfigurations.vehicleTypeConfiguration(1).objectChange(6)#mrAddMassCOMActive" value="0 2.1 -0.15"/>

            <!-- center of mass of seeding hopper -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.4 -0.15"/>


            <!-- transport wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="130"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="130"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#initialCompression" value="17"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#initialCompression" value="17"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#restLoad" value="2.25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#restLoad" value="2.25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mrNoGroundDisplacementWhenLowered" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mrNoGroundDisplacementWhenLowered" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#supportsWheelSink" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#supportsWheelSink" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.1"/>

            <!-- support wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#restLoad" value="0.8"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#restLoad" value="0.8"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mrFrictionScale" value="0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrFrictionScale" value="0.1"/>


            <set path="vehicle.powerConsumer#maxForce" value="24" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="3" /> <!-- small hydraulic turbine -->
            <set path="vehicle.powerConsumer#ptoRpm" value="340" /> <!-- no pto = only hydraulics, no need for high rev -->

            <set path="vehicle.base.speedLimit#value" value="16" />

            <!-- slower folding speed -->
            <set path="vehicle.foldable.foldingConfigurations.foldingConfiguration.foldingParts.foldingPart(0)#speedScale" value="0.7" />

            <set path="vehicle.attachable.brakeForce#force" value="0.9"/> <!-- small air brakes -->



        </attributes>
    </parentFile>

</vehicle>