<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="augerWagon" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <mrPowerConsumer forcePtoRpm="true" ptoPowerStartingTime="3000" /> <!-- forcePtoRpm means we want full pto rpm even at idle/not moving -->

    <mrSuspension referenceMass="60000" />

    <!--


        1690 bushels => 59.55 M3 // 2100 ft3 => 59.5 M3 // 80000 lbs capacity (36 287 kilos)
        52000 lbs empty (23 586 kilos)

        the cart is equipped with a rear weight rack => 1500lbs (680kg)

    -->

    <parentFile xmlFilename="$data/vehicles/amityTechnology/cc1000/cc1000.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.6 -1.2"/>
            <set path="vehicle.base.components.component(0)#mass" value="19600"/>


            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="60" />

            <remove path="vehicle.attachable.brakeForce" />
            <remove path="vehicle.attachable.airConsumer" />
            <set path="vehicle.attachable.brakeForce#force" value="0"/>


            <!-- track setup -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.2"/> <!-- left back -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.25"/> <!-- left front -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#suspTravel" value="0.2"/> <!-- right back -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#suspTravel" value="0.25"/> <!-- right front -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mrFrictionScale" value="0.7"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrFrictionScale" value="0.7"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="500"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="200"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="500"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="200"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="15"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#yOffset" value="-0.1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#yOffset" value="-0.1"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mass" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mass" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mass" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mass" value="1"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#supportsWheelSink" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#supportsWheelSink" value="true"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#initialCompression" value="14"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#initialCompression" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#initialCompression" value="14"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#initialCompression" value="0"/>

            <!-- end wheel configs -->

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.2 -1.9"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#capacity" value="59500"/>

            <!-- empty speed -->
            <set path="vehicle.dischargeable.dischargeNode(0)#emptySpeed" value="5500"/>

            <!-- drawbar protection against tractor's wheel -->
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint#lowerRotLimitScale" value="1 1 1" />

            <!-- moving center of mass -->
            <set path="vehicle.animations.animation(0).part(489)#componentIndex" value="1" /> <!-- main component -->
            <set path="vehicle.animations.animation(0).part(489)#startTime" value="0" />
            <set path="vehicle.animations.animation(0).part(489)#endTime" value="3" />
            <set path="vehicle.animations.animation(0).part(489)#startCenterOfMass" value="0 1.6 -1.2" />
            <set path="vehicle.animations.animation(0).part(489)#endCenterOfMass" value="-0.5 3.6 -1.2" />

            <!-- animation speed -->
            <set path="vehicle.pipe.animation#speedScale" value="0.4" />
            <set path="vehicle.dischargeable.dischargeNode.stateObjectChanges.objectChange(0)#interpolationTime" value="6" />
            <set path="vehicle.dischargeable.dischargeNode.stateObjectChanges.objectChange(1)#interpolationTime" value="6" />


            <set path="vehicle.dischargeable.dischargeNode.effects.effectNode(0).effectNode(1)#fadeTime" value="0.5" />
            <set path="vehicle.dischargeable.dischargeNode.effects.effectNode(0).effectNode(1)#delay" value="4" />

            <set path="vehicle.dischargeable.dischargeNode.effects.effectNode(1)#fadeTime" value="0.5" />
            <set path="vehicle.dischargeable.dischargeNode.effects.effectNode(1)#delay" value="3.5" />
            <set path="vehicle.dischargeable.dischargeNode.effects.effectNode(1)#uvSpeed" value="0.1" />


        </attributes>
    </parentFile>

</vehicle>