<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="cultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.3" />

    <!--

        about 7870kg "vanilla"

        options =
        air brakes
        VIBRO-BOARD
        Warning signs with holder and LED-lights
        => about 8400kg

        only "shallow" mode = 8-9cm

        60 tines

         -->

    <parentFile xmlFilename="$data/vehicles/einboeck/taifun900/taifun900.xml">
        <attributes>

            <set path="vehicle.powerConsumer#maxForce" value="55" />

            <set path="vehicle.base.components.component(0)#inertiaScale" value="1 1 1" />

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.5 -0.35" />
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 -0.25 -0.5" />
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 0 -0.1" />
            <set path="vehicle.base.components.component(3)#centerOfMass" value="0 -0.1 -1" />
            <set path="vehicle.base.components.component(4)#centerOfMass" value="0 -0.15 -1.2" />
            <set path="vehicle.base.components.component(5)#centerOfMass" value="0 -0.1 -1" />
            <set path="vehicle.base.components.component(6)#centerOfMass" value="0 -0.15 -1.2" />

            <!--  weight of rollers and support wheels and virtual wheels are added at game time -->
            <set path="vehicle.base.components.component(0)#mass" value="4450" /> <!-- main -->
            <set path="vehicle.base.components.component(1)#mass" value="600" /> <!-- drawbar -->
            <set path="vehicle.base.components.component(2)#mass" value="500" /> <!-- attacher -->
            <set path="vehicle.base.components.component(3)#mass" value="500" /> <!-- left wing -->
            <set path="vehicle.base.components.component(4)#mass" value="150" /> <!-- left far wing -->
            <set path="vehicle.base.components.component(5)#mass" value="500" /> <!-- right wing -->
            <set path="vehicle.base.components.component(6)#mass" value="150" /> <!-- right far wing,-->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#brakeFactor" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#brakeFactor" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#brakeFactor" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#brakeFactor" value="0"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="65"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="65"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="10"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#supportsWheelSink" value="true" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#supportsWheelSink" value="true" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#mrNoGroundDisplacementWhenLowered" value="true" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mrNoGroundDisplacementWhenLowered" value="true" />

            <!-- central part working support "wheels" -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="25"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#spring" value="100"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(8).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(12).physics#spring" value="20"/>

            <set path="vehicle.attachable.brakeForce#force" value="2" /> <!-- small air brakes -->

            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerRotLimitScale" value="0 0 2" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#upperRotLimitScale" value="0 0 2" />

            <!-- remove unatural moving center of mass -->
            <remove path="vehicle.animations.animation(2).part(20)" />
            <remove path="vehicle.animations.animation(2).part(20)" />
            <remove path="vehicle.animations.animation(2).part(20)" />
            <remove path="vehicle.animations.animation(2).part(20)" />

        </attributes>
    </parentFile>

</vehicle>