<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="fertilizingSowingMachine" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <mrPowerConsumer forcePointY="0" forcePointZ="-5" />

<!--

    The Citan is a solo seed drill for areas which have
    been already been worked and which are ready
    for sowing

    option in game =
    - electric distribution
    - rear press wheels
    - clear track tines

    total empty mass = about 12000kg

    bug present :
    - rear press wheels are not rotating while working
    - support wheels should be 400/50R15.5


-->

    <parentFile xmlFilename="$data/vehicles/amazone/citan15001C/citan15001C.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="16" />

            <set path="vehicle.attachable.brakeForce#force" value="2" /> <!-- pneumatic brake -->

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1 -0.1" /> <!-- main body -->
            <set path="vehicle.base.components.component(0)#mass" value="6300" />

            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0 -0.35" /> <!--drawbar-->
            <set path="vehicle.base.components.component(1)#mass" value="450" />

            <!-- seed ramp -->
            <set path="vehicle.base.components.component(2)#centerOfMass" value="-0.5 0 0.2" />
            <set path="vehicle.base.components.component(2)#mass" value="2500" />

            <set path="vehicle.base.components.component(3)#centerOfMass" value="0.5 0 0.2" />
            <set path="vehicle.base.components.component(3)#mass" value="2500" />


            <!-- wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="120"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="120"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="6"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="40"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="40"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#spring" value="40"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#spring" value="40"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="6"/>

            <set path="vehicle.powerConsumer#maxForce" value="40" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="35" /> <!-- air turbine (seeds + ferti) + electric distribution -->
            <set path="vehicle.powerConsumer#ptoRpm" value="385" />

            <!-- seeds hopper center of mass, 7800L total -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.1 1.8"/> <!-- fertilizer 3000L -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#fillTypes" value="fertilizer"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(1)#mrCenterOfMass" value="0 2.1 3.3"/> <!-- seeds = 2x2400L -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(1)#fillTypes" value="seeds"/>
            <set path="vehicle.sowingMachine#fillUnitIndex" value="2"/>
            <set path="vehicle.sprayer#fillUnitIndex" value="1"/>
            <set path="vehicle.sprayer#unloadInfoIndex" value="1"/>

            <!-- limit attacher rot limit -->
            <set path="animations.animation(1).part(0)#startRotLimit" value="0 50 80" />

        </attributes>
    </parentFile>

</vehicle>