<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="turnOnCultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.1" forcePointZ="0.4" ptoForSoilWork="true" />
    <mrImplement processAreaWhileNotMoving="true" />

    <!--
    base weight : 5623kg with tube roller
    in game spec = about 6400kg with packer roller

    280Hp tractor required. up to 430Hp possible

    no brakes

    -->

    <parentFile xmlFilename="$data/vehicles/bednar/katorKNProfi8000/katorKNProfi8000.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#mass" value="4400" />
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.4 0.6" />

            <set path="vehicle.powerConsumer#maxForce" value="36" />
            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <set path="vehicle.powerConsumer#neededMinPtoPower" value="180" /> <!-- this is the pto power when working at 8kph => less power needed when working slower. Idle pto power = 10% -->
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="180" /> <!-- difference between min and max = only for "cylindered" => hydraulics -->

            <remove path="vehicle.attachable.brakeForce" />


            <!-- transport wheels -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="60"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="60"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="5"/>


            <!-- roller -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mass" value="0.47"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mass" value="0.47"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#mass" value="0.47"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#mass" value="0.47"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mrKeepMass" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrKeepMass" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#mrKeepMass" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#mrKeepMass" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#rotationDamping" value="0.0025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#rotationDamping" value="0.0025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#rotationDamping" value="0.0025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#rotationDamping" value="0.0025"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mrFrictionScale" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrFrictionScale" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#mrFrictionScale" value="0.5"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#mrFrictionScale" value="0.5"/>

            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#mrLowerRotationOffset" value="0" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#upperRotationOffset" value="0" />
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#upperRotLimitScale" value="0 0 0.5" />

            <!-- allow some x flexibility at work -->
            <set path="vehicle.animations.animation(1).part(1)#lowerRotLimitScaleStart" value="0.05 0 0" />

            <!-- moving center of mass when folding -->
            <set path="vehicle.animations.animation(1).part(13)#componentIndex" value="1" />
            <set path="vehicle.animations.animation(1).part(13)#startTime" value="1" />
            <set path="vehicle.animations.animation(1).part(13)#endTime" value="8" />
            <set path="vehicle.animations.animation(1).part(13)#startCenterOfMass" value="0 0.4 0.3" />
            <set path="vehicle.animations.animation(1).part(13)#endCenterOfMass" value="0 2 0.3" />


        </attributes>
    </parentFile>

</vehicle>