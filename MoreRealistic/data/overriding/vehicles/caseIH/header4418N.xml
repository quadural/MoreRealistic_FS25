<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="cutter" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>

    <mrPowerConsumer maxGroundDistance="0.4" /> <!-- we don't want to apply draftforce when harvesting sunflower -->

    <parentFile xmlFilename="$data/vehicles/caseIH/header4418N/header4418N.xml">
        <attributes>

            <!-- 4799kg with chopping units -->
            <set path="vehicle.base.speedLimit#value" value="12" /> <!-- less speed because of the chopping feature -->
            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.4 -0.4" />
            <set path="vehicle.base.components.component(0)#mass" value="4800" />

            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="50" />
            <set path="vehicle.powerConsumer#maxForce" value="27" /> <!-- more draftforce because of the chopping feature -->
            <set path="vehicle.powerConsumer#forceNode" value="header4418N_main_component1" />

        </attributes>
    </parentFile>

</vehicle>