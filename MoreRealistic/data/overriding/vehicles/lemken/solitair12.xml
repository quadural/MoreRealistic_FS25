<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="sowingMachine" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

<MR>true</MR>

<!--


-->

    <parentFile xmlFilename="$data/vehicles/lemken/solitair12/solitair12.xml">
        <attributes>

            <set path="vehicle.base.speedLimit#value" value="15" />

            <set path="vehicle.attachable.brakeForce#force" value="3" /> <!-- pneumatic brake -->

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1 0.12" />
            <set path="vehicle.base.components.component(0)#mass" value="3050" />

            <!-- seed ramp -->
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 2 0.2" />
            <set path="vehicle.base.components.component(1)#mass" value="1700" />

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="70"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="70"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="6"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="6"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#supportsWheelSink" value="false" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#supportsWheelSink" value="false" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#supportsWheelSink" value="false" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#supportsWheelSink" value="false" />


            <set path="vehicle.powerConsumer#maxForce" value="34" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="25" /> <!-- air turbine + electric distribution -->

            <!-- "folding animation" = moving center of masses -->
            <set path="vehicle.animations.animation(0).part(11)#startTime" value="6.5" />
            <set path="vehicle.animations.animation(0).part(11)#endTime" value="13" />
            <set path="vehicle.animations.animation(0).part(11)#startCenterOfMass" value="0 -0.1 0.2" />
            <set path="vehicle.animations.animation(0).part(11)#endCenterOfMass" value="0 2 0.2" />
            <set path="vehicle.animations.animation(0).part(11)#componentIndex" value="2" />

            <!-- seeds hopper center of mass -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 1.4 0"/>

        </attributes>
    </parentFile>

</vehicle>