<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="trailer" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR inlineAxleNumber="3">true</MR>

    <mrSuspension referenceMass="26000" />

    <!--

        about 7200kg empty (385/65R22.5 + 800&800)

        Platform size inside = 7230 x 2410
        800+800 extension = 27.9M3

        ingame = 800+500 (22.5m3) or 800+600+600 (34M3) ? doesn't seem to match. The 2 extensions are the same in game. so, it should be 800+600 and 800+600+600.
        but the difference in height = 670mm between the 2 fillvolume
        and the difference between the extension and the main side = 150mm => main side = 800mm and extension = 650mm ? that doesn't match
        by checking in the i3d again, the first fillvolume is 9cm too small in height
        which means that instead of 700mm difference in height between the 2 fillvolume, there is only there is only 610mm now (which match a 600mm extension this time)

        so, the visual = 800+600 (24.39M3) and 800+600+600 (34.85M3)
        => we can modify the first extension level capacity to 24.4M3

        ingame 24.4M3 = 7050kg

    -->

    <parentFile xmlFilename="$data/vehicles/brantner/dd24073/dd24073.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.35 -1.7"/> <!-- main -->
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 -0.3 0"/> <!-- front axle -->
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 0 -0.35"/> <!-- drawbar -->

            <set path="vehicle.base.components.component(0)#mass" value="3300"/>
            <set path="vehicle.base.components.component(1)#mass" value="1400"/>
            <set path="vehicle.base.components.component(2)#mass" value="600"/>

            <remove path="vehicle.attachable.brakeForce" />
