            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(5)#centerOfMass" value="0 0.1 -0.6" />


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="150"/> <!-- lift wheel left wing -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#mrForcePointRatio" value="0.1"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="150"/> <!-- lift wheel left outer wing -->
