            <set path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(65)#endTime" value="14" />


            <!-- remove not realistic moving center of mass -->
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(48)#startCenterOfMass" />
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(48)#endCenterOfMass" />
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(49)#startCenterOfMass" />
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(49)#endCenterOfMass" />

            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(66)#startCenterOfMass" />
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(66)#endCenterOfMass" />
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(67)#startCenterOfMass" />
            <remove path="vehicle.animations.animationConfigurations.animationConfiguration(0).animation(1).part(67)#endCenterOfMass" />


