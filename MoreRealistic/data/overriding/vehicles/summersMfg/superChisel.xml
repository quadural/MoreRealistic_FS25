<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="cultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.9" />

    <!--
    base weight : 12464kg (Weight includes mounted harrows, which are standard with this model)

    no brakes / 20mph (32kph) road speed

    "deep" mode = 15-17cm
    "shallow" mode = 8-9cm
    => difference = about 8cm "height"

    gauge wheels should be IF280/70R15 (11L x 15)

    -->

    <parentFile xmlFilename="$data/vehicles/summersMfg/superChisel/superChisel.xml">
        <attributes>
            <set path="vehicle.powerConsumer#maxForce" value="160" />

            <set path="vehicle.attachable.brakeForce#force" value="0" />

            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(0)#mass" value="4020" /> <!-- main -->
            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(0)#centerOfMass" value="0 1.1 -2.1" />

            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(1)#mass" value="2500" /> <!-- wing left -->
            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(1)#centerOfMass" value="0 0 -0.8" />

            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(2)#mass" value="1100" /> <!-- outer wing left -->
            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(2)#centerOfMass" value="-0.6 -0.4 -0.45" />

            <set path="vehicle.base.componentConfigurations.componentConfiguration(0).component(3)#mass" value="2500" /> <!-- wing right -->
