<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="dynamicMountAttacherTrailer" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

<MR inlineAxleNumber="3">true</MR>

    <!--
        18T total weight

        base game attachable brakeForce = multiplied by 10 and apply to each wheel
        and so, it means a 6 wheels trailer get 60KN braking force by setting the value of 1
        in our case, this trailer is well equiped to brake up to 24T @60kph

        brake cam 300*90

        18T, 60% brake efficiency => 18*0.6/6 = 1.8

        weight = about 4075kg with ingame spec

    -->

    <parentFile xmlFilename="$data/vehicles/farmtech/dpw1800/dpw1800.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.9 -1.5"/> <!-- main -->
            <set path="vehicle.base.components.component(1)#centerOfMass" value="0 0 0"/> <!-- front axle -->
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0 0 -0.6"/> <!-- drawbar -->

            <set path="vehicle.base.components.component(0)#mass" value="2230"/>
            <set path="vehicle.base.components.component(1)#mass" value="1000"/>
            <set path="vehicle.base.components.component(2)#mass" value="300"/>

            <remove path="vehicle.base.components.component(0)#inertiaScale" />
            <remove path="vehicle.base.components.component(1)#inertiaScale" />
            <remove path="vehicle.base.components.component(2)#inertiaScale" />

            <set path="vehicle.attachable.brakeForce#force" value="1.8"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0)#dimensions" value="480_45R17"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1)#dimensions" value="480_45R17"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#dimensions" value="480_45R17"/>
