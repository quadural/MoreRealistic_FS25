            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(6)#mrAddMassActive" value="200"/>
            <set path="vehicle.designConfigurations.designConfiguration(1).objectChange(6)#mrAddMassCOMActive" value="0 1.7 -0.8"/>


