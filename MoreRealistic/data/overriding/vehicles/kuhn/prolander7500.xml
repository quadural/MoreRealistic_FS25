<?xml version="1.0" encoding="utf-8" standalone="no"?>
<vehicle type="cultivator" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR>true</MR>
    <mrPowerConsumer forcePointY="0.2" />

    <!--

        5075kg (double "u" roller) + rear harrow => about 5400kg

        only "shallow" mode = 8-9cm

         -->

    <parentFile xmlFilename="$data/vehicles/kuhn/prolander7500/prolander7500.xml">
        <attributes>

            <set path="vehicle.powerConsumer#maxForce" value="45" />

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 0.6 -0.1" />
            <set path="vehicle.base.components.component(1)#centerOfMass" value="-0.25 -0.1 0.1" />
            <set path="vehicle.base.components.component(2)#centerOfMass" value="0.25 -0.1 0.1" />

            <set path="vehicle.base.components.component(0)#mass" value="2300" />
            <set path="vehicle.base.components.component(1)#mass" value="1000" />
            <set path="vehicle.base.components.component(2)#mass" value="1000" />
            <set path="vehicle.base.components.component(3)#mass" value="300" />

            <!-- remove unreal moving center of masses -->
            <remove path="vehicle.animations.animation(0).part(2)" />
            <remove path="vehicle.animations.animation(0).part(2)" />

            <!-- fix lowering / folding animation = reduce the back wheels "jittering" when lowering the tool -->
            <set path="vehicle.animations.animation(0).part(12)#startTime" value="0.1" />
            <set path="vehicle.animations.animation(0).part(12)#endTime" value="0.7" />


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="10"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#mrFrictionScale" value="0.3"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#mrFrictionScale" value="0.3"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#width" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#width" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#width" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#width" value="1"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#damper" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#damper" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#damper" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#damper" value="50"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(4).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(5).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(6).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(7).physics#supportsWheelSink" value="false"/>

            <!-- correct wheels -->
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0)#dimensions" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1)#dimensions" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0)#filename" value="$data/shared/wheels/tires/vredestein/flotationTrac/520_50R17.xml"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1)#filename" value="$data/shared/wheels/tires/vredestein/flotationTrac/520_50R17.xml"/>

            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#dimensions" />
            <remove path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3)#dimensions" />
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2)#filename" value="$data/shared/wheels/tires/trelleborg/AW305/340_55R16.xml"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3)#filename" value="$data/shared/wheels/tires/trelleborg/AW305/340_55R16.xml"/>

            <!-- take into account new front wheel size (warning when counting index : there are 2 indexes removed previously)-->
            <set path="vehicle.animations.animation(0).part(14)#startTime" value="0" />
            <set path="vehicle.animations.animation(0).part(15)#startTime" value="0" />
            <set path="vehicle.animations.animation(0).part(16)#startTime" value="0" />
            <set path="vehicle.animations.animation(0).part(17)#startTime" value="0" />
            <set path="vehicle.animations.animation(0).part(14)#endTime" value="0.8" />
            <set path="vehicle.animations.animation(0).part(15)#endTime" value="0.8" />
            <set path="vehicle.animations.animation(0).part(16)#endTime" value="0.8" />
            <set path="vehicle.animations.animation(0).part(17)#endTime" value="0.8" />
            <set path="vehicle.animations.animation(0).part(14)#startRot" value="-20 -90 0" />
            <set path="vehicle.animations.animation(0).part(15)#startRot" value="-20 0 0" />
            <set path="vehicle.animations.animation(0).part(16)#startRot" value="-20 90 0" />
            <set path="vehicle.animations.animation(0).part(17)#startRot" value="-20 0 0" />

        </attributes>
    </parentFile>

</vehicle>