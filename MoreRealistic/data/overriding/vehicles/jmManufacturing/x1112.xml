<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="augerWagon" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR inlineAxleNumber="1">true</MR>

    <mrPowerConsumer forcePtoRpm="true" ptoPowerStartingTime="3000" /> <!-- forcePtoRpm means we want full pto rpm even at idle/not moving -->

    <mrSuspension referenceMass="43000" />

    <!--

        no brakes on this one ! => only drive empty on road

        option in game =
        tarp
        scaling system

        total mass with michelin mega xbib = 6980kg

        total mass with dual 520 = 9050kg

        total mass with "stabilizer" tracks = 10510kg (on the website, they say 5430lbs = 2463kg per track for the 36" stabilizer version)

    -->

    <parentFile xmlFilename="$data/vehicles/jmManufacturing/x1112/x1112.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.6 -0.2"/>
            <set path="vehicle.base.components.component(0)#mass" value="5580"/>

            <set path="vehicle.powerConsumer#ptoRpm" value="540" />
            <set path="vehicle.powerConsumer#neededMaxPtoPower" value="90" />

            <remove path="vehicle.attachable.brakeForce" />
            <remove path="vehicle.attachable.airConsumer" />
            <set path="vehicle.attachable.brakeForce#force" value="0"/>

            <!-- <set path="vehicle.connectionHoses.hose(4).objectchange#visibilityInactive" value="false" /> -->
            <!-- <set path="vehicle.connectionHoses.hose(5).objectchange#visibilityInactive" value="false" /> -->
            <remove path="vehicle.connectionHoses.hose(4)" />
            <remove path="vehicle.connectionHoses.hose(4)" />
            <remove path="vehicle.connectionHoses.sounds.connect(0)" />
            <remove path="vehicle.connectionHoses.sounds.disconnect(0)" />

            <!-- removing the visual of the air lines detached -->
            <set path="vehicle.base.objectChanges.objectchange(0)#node" value="airIn_detached" />
            <set path="vehicle.base.objectChanges.objectchange(0)#visibilityActive" value="false" />
            <set path="vehicle.base.objectChanges.objectchange(1)#node" value="airOut_detached" />
            <set path="vehicle.base.objectChanges.objectchange(1)#visibilityActive" value="false" />




            <!-- wheel setup -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.12"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.12"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="200"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="200"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="12"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="12"/>


            <!-- walking beam setup -->

            <!-- more mass to the frame -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).objectChange(2)#node" value="x1112Single_main_component1"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).objectChange(2)#mrAddMassActive" value="1750"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).objectChange(2)#mrAddMassCOMActive" value="0 0.7 -1.3"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#suspTravel" value="0.15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#suspTravel" value="0.15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#suspTravel" value="0.15"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#suspTravel" value="0.15"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#spring" value="140"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#spring" value="140"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#spring" value="140"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#spring" value="140"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#damper" value="14"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#damper" value="14"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#damper" value="10"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#damper" value="10"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(0).physics#yOffset" value="0.012"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(1).physics#yOffset" value="0.012"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(2).physics#yOffset" value="0.02"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(1).wheels.wheel(3).physics#yOffset" value="0.02"/>

            <!-- track setup -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#suspTravel" value="0.15"/> <!-- left back -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#suspTravel" value="0.15"/> <!-- left front -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#suspTravel" value="0.15"/> <!-- right back -->
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#suspTravel" value="0.15"/> <!-- right front -->

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#spring" value="140"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#spring" value="175"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#spring" value="140"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#spring" value="175"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#damper" value="20"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#yOffset" value="-0.045"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#yOffset" value="0"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#yOffset" value="-0.045"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#mass" value="1.23"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#mass" value="1.23"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#mass" value="1.23"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#mass" value="1.23"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(0).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(1).physics#supportsWheelSink" value="true"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(2).physics#supportsWheelSink" value="false"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(2).wheels.wheel(3).physics#supportsWheelSink" value="true"/>





            <!-- end wheel configs -->

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.3 -1.4"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.3 -1.35"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(2).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.3 -1.4"/>

            <!-- empty speed -->
            <set path="vehicle.dischargeable.dischargeNode(0)#emptySpeed" value="350"/>

            <!-- drawbar protection against tractor's wheel -->
            <set path="vehicle.attachable.inputAttacherJointConfigurations.inputAttacherJointConfiguration(0).inputAttacherJoint#lowerRotLimitScale" value="1 0.85 1" />
            <set path="vehicle.attachable.inputAttacherJointConfigurations.inputAttacherJointConfiguration(1).inputAttacherJoint#lowerRotLimitScale" value="1 0.85 1" />
            <set path="vehicle.attachable.inputAttacherJointConfigurations.inputAttacherJointConfiguration(2).inputAttacherJoint#lowerRotLimitScale" value="1 0.85 1" />

            <!-- unloading "stream" of grain -->
            <set path="vehicle.dischargeable.dischargeNode.effects.effectNode(0)#maxBending" value="0.8"/>

        </attributes>
    </parentFile>

</vehicle>