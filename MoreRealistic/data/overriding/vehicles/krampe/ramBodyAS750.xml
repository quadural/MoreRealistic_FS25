<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="trailer" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">

    <MR inlineAxleNumber="2">true</MR>

    <mrSuspension referenceMass="44000" />

    <!--

        Krampe RamBody 750 plus (volume tailgate)
        volume without extension = 38.6M3
        volume with 30cm extension = 44.5M3

        empty weight 8400 with 600/55R26.5, no extension, no steering axle

        ingame spec =
        pneumatic suspension
        steering axle
        hydraulically foldable underride guard

    -->

    <parentFile xmlFilename="$data/vehicles/krampe/ramBodyAS750/ramBodyAS750.xml">
        <attributes>

            <set path="vehicle.base.components.component(0)#centerOfMass" value="0 1.75 -0.8"/>
            <set path="vehicle.base.components.component(0)#mass" value="7700"/>

            <remove path="vehicle.attachable.brakeForce" />
            <set path="vehicle.attachable.brakeForce#force" value="2.5"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#suspTravel" value="0.18"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#suspTravel" value="0.18"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#suspTravel" value="0.18"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#suspTravel" value="0.18"/>


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#spring" value="110"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#spring" value="110"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#spring" value="100"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#spring" value="100"/>


            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#damper" value="20"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#damper" value="20"/>

            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(0).physics#yOffset" value="0.035"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(1).physics#yOffset" value="0.035"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(2).physics#yOffset" value="0.035"/>
            <set path="vehicle.wheels.wheelConfigurations.wheelConfiguration(0).wheels.wheel(3).physics#yOffset" value="0.035"/>



            <!-- extension -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).objectChange(8)#node" value="ramBodyAS750_main_component1"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).objectChange(8)#mrAddMassActive" value="100"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).objectChange(8)#mrAddMassCOMActive" value="0 3.8 -1.3"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(1).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.6 -0.7"/>

            <!-- no extension -->
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit(0)#mrCenterOfMass" value="0 2.45 -0.7"/>

            <!-- empty speed -->
            <set path="vehicle.dischargeable.dischargeNode(0)#emptySpeed" value="1600"/> <!-- back -->
            <set path="vehicle.dischargeable.dischargeNode(1)#emptySpeed" value="480"/> <!-- grain door -->

            <!-- drawbar protection against tractor's wheel -->
            <set path="vehicle.attachable.inputAttacherJoints.inputAttacherJoint(0)#lowerRotLimitScale" value="1 0.81 1" />

            <!-- 25s pushing time -->
            <set path="vehicle.trailer.trailerConfigurations.trailerConfiguration(0).trailer.tipSide(0).animation#speedScale" value="0.6" />

            <!-- 80s pushing time -->
            <set path="vehicle.trailer.trailerConfigurations.trailerConfiguration(0).trailer.tipSide(1).animation#speedScale" value="0.1875" />

            <!-- steering axle speed limit -->
            <set path="vehicle.attachable.steeringAxleAngleScale#endSpeed" value="20" />

        </attributes>
    </parentFile>

</vehicle>